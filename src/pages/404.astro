---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout
  title="Không tìm thấy trang — Linhchiaura"
  description="Trang bạn đang tìm không tồn tại hoặc đã được chuyển sang một địa chỉ khác."
  canonical="/404"
  robots="noindex, follow"
>
  <div class="lc-page">
    <main class="lc-error-main">
      <section class="lc-error-card" aria-labelledby="lc-error-title">
        <div class="lc-error-ornament" aria-hidden="true">
          <span>🌿</span>
          <strong>404</strong>
          <span>✨</span>
        </div>
        <p class="lc-error-eyebrow">Có lẽ bạn vừa rẽ nhầm một lối nhỏ</p>
        <h1 id="lc-error-title" class="lc-error-title">Trang này không còn ở đây</h1>
        <p class="lc-error-description">
          Không sao cả, mình cùng quay lại Đọc sâu để tiếp tục hành trình nhé.
        </p>
        <a class="lc-error-home" href="/">← Về trang chủ</a>
      </section>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>

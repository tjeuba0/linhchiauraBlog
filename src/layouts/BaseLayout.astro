---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  image?: string;
  imageAlt?: string;
  publishedTime?: Date | string;
  robots?: string;
}

const {
  title,
  description = 'Nhật ký, giới thiệu và hộp thư riêng tư của Linhchiaura — nơi vẻ đẹp tâm hồn được trân trọng.',
  canonical,
  ogType = 'website',
  image = '/cover.jpg',
  imageAlt = 'Linhchiaura — hành trình yêu thương bản thân',
  publishedTime,
  robots = 'index, follow',
} = Astro.props;

const baseURL = Astro.site ?? Astro.url;
const canonicalURL = new URL(canonical ?? Astro.url.pathname, baseURL);
const imageURL = new URL(image, baseURL);
const publishedTimeISO = publishedTime
  ? new Date(publishedTime).toISOString()
  : undefined;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f4faf5" />

    <script is:inline>
      const root = document.documentElement;
      window.addEventListener('pointerdown', () => (root.dataset.lcInput = 'pointer'), true);
      window.addEventListener('keydown', () => (root.dataset.lcInput = 'keyboard'), true);

      try {
        const saved = JSON.parse(localStorage.getItem('lc-reading') || '{}');
        const size = Math.min(24, Math.max(15, typeof saved.size === 'number' ? saved.size : 17));
        document.documentElement.style.setProperty('--lc-reader-size', `${size}px`);
        document.documentElement.dataset.lcReaderBold = saved.bold === true ? 'true' : 'false';
        document.documentElement.dataset.lcReaderItalic = saved.italic === true ? 'true' : 'false';
      } catch {
        document.documentElement.style.setProperty('--lc-reader-size', '17px');
      }
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalURL} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Linhchiaura — Nhật ký"
      href={new URL('/rss.xml', baseURL)}
    />

    <meta property="og:locale" content="vi_VN" />
    <meta property="og:site_name" content="Linhchiaura" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:alt" content={imageAlt} />
    {publishedTimeISO && <meta property="article:published_time" content={publishedTimeISO} />}
    {ogType === 'article' && <meta property="article:author" content="Linhchiaura" />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

---
// Cover/avatar are pre-optimized static files in public/ (served verbatim, no
// build-time Sharp) so they render on any host, including Cloudflare Pages.
const socials = [
  {
    label: 'Email',
    href: 'mailto:Nguyenlinhchi21@gmail.com',
    external: false,
    inner:
      '<rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>',
  },
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/mosakid/',
    external: true,
    inner:
      '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>',
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/linh-chi-nguyen-8349961ab/',
    external: true,
    inner:
      '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle>',
  },
  {
    label: 'Instagram',
    href: 'https://instagram.com/linhchiaura',
    external: true,
    inner:
      '<rect x="2" y="2" width="20" height="20" rx="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>',
  },
  {
    label: 'Website',
    href: '/',
    external: false,
    inner:
      '<circle cx="12" cy="12" r="10"></circle><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path><path d="M2 12h20"></path>',
  },
];
---

<div class="lc-profile">
  <div class="lc-cover">
    <picture class="lc-cover-picture">
      <source
        type="image/webp"
        srcset="/cover-v1-480.webp 480w, /cover-v1-960.webp 960w, /cover-v1-1760.webp 1760w"
        sizes="(max-width: 640px) calc(100vw - 28px), 880px"
      />
      <img
        class="lc-cover-img"
        src="/cover.jpg"
        alt=""
        width="1760"
        height="756"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </picture>
  </div>
  <div class="lc-avatar">
    <picture class="lc-avatar-picture">
      <source
        type="image/webp"
        srcset="/avatar-v1-96.webp 96w, /avatar-v1-192.webp 192w, /avatar-v1-264.webp 264w"
        sizes="(max-width: 380px) 84px, (max-width: 640px) 92px, 132px"
      />
      <img
        class="lc-avatar-img"
        src="/avatar.jpg"
        alt="Linhchiaura"
        width="264"
        height="264"
        loading="eager"
        decoding="async"
      />
    </picture>
  </div>
  <div class="lc-profile-body">
    <h1 class="lc-name">Linhchiaura</h1>
    <p class="lc-bio">"Hành trình học cách yêu thương bản thân đúng đắn!" ✨💖</p>
    <p class="lc-intro">
      Welcome bạn đến với thế giới tự do của Linhchiaura — nơi vẻ đẹp tâm hồn được
      trân trọng. Mình là một Dược sĩ đang theo đuổi Tâm lý học và ghi lại hành trình
      trưởng thành, bình an, yêu thương bản thân. 🌿✨
    </p>
    <div class="lc-social">
      {
        socials.map((s) => (
          <a
            href={s.href}
            title={s.label}
            aria-label={s.label}
            target={s.external ? '_blank' : undefined}
            rel={s.external ? 'noopener noreferrer' : undefined}
          >
            <svg
              width="17"
              height="17"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={s.inner}
            />
          </a>
        ))
      }
    </div>
  </div>
</div>
